#!/bin/sh
# Block a commit that would break either hard guarantee. Enable once per clone:
#   git config core.hooksPath .githooks
#   1. IP-content limits (≤20s voice, ≤~1 page text, no bulk artifacts).
#   2. Safe code patterns (no HTML-string DOM build, no parenthesised eval-mode call).
set -e
root="$(git rev-parse --show-toplevel)"
python3 "$root/tools/check_ip_limits.py"
python3 "$root/tools/check_safe_patterns.py"
